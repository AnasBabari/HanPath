# OpenRouter API key (required)
VITE_OPENROUTER_API_KEY=sk-or-v1-your-key

# Supabase project config (required for cloud progress sync)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional comma-separated free model priority list
# The app also discovers current :free models from OpenRouter automatically.
VITE_OPENROUTER_FREE_MODELS=arcee-ai/trinity-large-preview:free,qwen/qwen3-4b:free,qwen/qwen3-coder:free
